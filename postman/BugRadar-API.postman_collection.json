    {
      "name": "🪝 Webhooks (inbound — reference only)",
      "description": "Platforms call these; you don't call them manually. Signature/token is verified per-repo. Manual calls without a valid secret return 401 — expected. Use the platform's Redeliver / Test button to trigger real deliveries.",
      "item": [
        {
          "name": "GitHub Webhook Receiver",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-GitHub-Event", "value": "ping" },
              { "key": "X-Hub-Signature-256", "value": "sha256=computed-by-github" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zen\": \"Keep it simple\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/github/{{tracked_repository_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "github", "{{tracked_repository_id}}"]
            },
            "description": "GitHub verifies with HMAC-SHA256 in X-Hub-Signature-256 header."
          }
        },
        {
          "name": "GitLab Webhook Receiver",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Gitlab-Event", "value": "Merge Request Hook" },
              { "key": "X-Gitlab-Token", "value": "shared-plaintext-secret" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object_kind\": \"merge_request\",\n  \"user\": { \"username\": \"alice\" },\n  \"object_attributes\": { \"id\": 1, \"title\": \"Test\", \"state\": \"opened\", \"action\": \"open\" }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/gitlab/{{tracked_repository_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "gitlab", "{{tracked_repository_id}}"]
            },
            "description": "GitLab verifies with plaintext token in X-Gitlab-Token header (matched against the repo's stored secret)."
          }
        },
        {
          "name": "Bitbucket Webhook Receiver",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Event-Key", "value": "pullrequest:created" },
              { "key": "X-Hub-Signature", "value": "sha256=computed-by-bitbucket" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pullrequest\": { \"id\": 1, \"title\": \"Test\", \"state\": \"OPEN\", \"author\": { \"display_name\": \"alice\" } }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/bitbucket/{{tracked_repository_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "bitbucket", "{{tracked_repository_id}}"]
            },
            "description": "Bitbucket verifies with HMAC-SHA256 in X-Hub-Signature header (same format as GitHub)."
          }
        }
      ]
    }
  ]
