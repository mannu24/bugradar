{
  "info": {
    "_postman_id": "bugradar-api-v2",
    "name": "BugRadar API v2",
    "description": "Complete BugRadar API collection.\n\n## Setup\n1. Import this collection\n2. Import one of the environment files (Local / Staging / Production)\n3. Select the environment in the top-right dropdown\n4. Run **Dev Login** first — token is saved automatically\n5. All other requests are ready to fire\n\n## Auth\nAll protected endpoints use `Authorization: Bearer {{auth_token}}` set at the collection level. The token is auto-saved by the Dev Login test script.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": { "major": 2, "minor": 0, "patch": 0 }
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": ["// Collection-level pre-request: nothing required — token set by Dev Login"]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level: log response time",
          "console.log(pm.info.requestName + ' → ' + pm.response.code + ' (' + pm.response.responseTime + 'ms)');"
        ]
      }
    }
  ],
  "variable": [
    { "key": "auth_token", "value": "", "type": "string", "description": "Auto-populated by Dev Login" },
    { "key": "integration_id", "value": "1", "type": "string", "description": "Set after listing integrations" },
    { "key": "pr_id", "value": "1", "type": "string", "description": "Set after listing pull requests" },
    { "key": "issue_id", "value": "1", "type": "string", "description": "Set after listing issues" },
    { "key": "review_id", "value": "1", "type": "string", "description": "Set after listing reviews" },
    { "key": "repo_full_name", "value": "owner/repo", "type": "string", "description": "e.g. manu/my-app — used by track/untrack" },
    { "key": "device_token", "value": "test-device-token-123", "type": "string", "description": "Any string for testing FCM registration" },
    { "key": "tracked_repository_id", "value": "1", "type": "string", "description": "TrackedRepository id — used in the webhook URL" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "description": "Authentication — login, OAuth, and logout.",
      "item": [
        {
          "name": "Dev Login (Local only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.environment.set('auth_token', json.token);",
                  "    pm.collectionVariables.set('auth_token', json.token);",
                  "    console.log('✅ Token saved: ' + json.token.substring(0, 20) + '...');",
                  "});",
                  "pm.test('Has user', () => pm.expect(pm.response.json().user).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/dev-login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "dev-login"]
            },
            "description": "⚠️ Local env only. Creates a test user and saves the token to `auth_token` environment variable automatically. Run this first."
          }
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user object', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.be.an('object');",
                  "    pm.expect(json.user.email).to.be.a('string');",
                  "    console.log('👤 Logged in as: ' + json.user.email);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/user",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "user"]
            },
            "description": "Returns the authenticated user's profile."
          }
        },
        {
          "name": "GitHub OAuth Login (Browser)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/github?redirect_url=bugradar://oauth-callback",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "github"],
              "query": [{ "key": "redirect_url", "value": "bugradar://oauth-callback", "description": "Deep link for mobile app" }]
            },
            "description": "Open this URL in a browser. Redirects to GitHub OAuth. After auth, deep-links back to the mobile app with ?token=xxx."
          }
        },
        {
          "name": "Google OAuth Login (Browser)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/google?redirect_url=bugradar://oauth-callback",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "google"],
              "query": [{ "key": "redirect_url", "value": "bugradar://oauth-callback" }]
            },
            "description": "Open this URL in a browser. Redirects to Google OAuth."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Logout success', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.environment.unset('auth_token');",
                  "pm.collectionVariables.set('auth_token', '');",
                  "console.log('🚪 Logged out — token cleared');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Revokes the current Bearer token. Token is cleared from env automatically."
          }
        }
      ]
    },

    {
      "name": "🔗 Integrations",
      "description": "Connect, manage, and sync GitHub / GitLab / Bitbucket integrations.",
      "item": [
        {
          "name": "List All Integrations",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns integrations array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.integrations).to.be.an('array');",
                  "    if (json.integrations.length > 0) {",
                  "        pm.environment.set('integration_id', json.integrations[0].id);",
                  "        pm.collectionVariables.set('integration_id', json.integrations[0].id);",
                  "        console.log('🔗 ' + json.integrations.length + ' integration(s) | First ID: ' + json.integrations[0].id);",
                  "    }",
                  "});",
                  "pm.test('Tokens not exposed', () => {",
                  "    const integrations = pm.response.json().integrations;",
                  "    if (integrations.length > 0) {",
                  "        pm.expect(integrations[0]).to.not.have.property('access_token');",
                  "        pm.expect(integrations[0]).to.not.have.property('refresh_token');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/integrations",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations"]
            },
            "description": "Returns all connected integrations. Access tokens are never exposed in this response."
          }
        },
        {
          "name": "Connect GitHub (Browser)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/integrations/github/connect?token={{auth_token}}",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "github", "connect"],
              "query": [{ "key": "token", "value": "{{auth_token}}", "description": "Your Sanctum token — links this OAuth to your account" }]
            },
            "description": "Open this URL in a browser (with your token). Redirects to GitHub OAuth for repo/issue access. On success shows a confirmation page."
          }
        },
        {
          "name": "Connect GitLab (Browser)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/integrations/gitlab/connect?token={{auth_token}}",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "gitlab", "connect"],
              "query": [{ "key": "token", "value": "{{auth_token}}" }]
            },
            "description": "Open in browser. Connects your GitLab account for MR and issue sync."
          }
        },
        {
          "name": "Connect Bitbucket (Browser)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/integrations/bitbucket/connect?token={{auth_token}}",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "bitbucket", "connect"],
              "query": [{ "key": "token", "value": "{{auth_token}}" }]
            },
            "description": "Open in browser. Connects your Bitbucket account for PR and issue sync."
          }
        },
        {
          "name": "Sync Integration",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Sync dispatched', () => {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "    console.log('⚡ Sync job queued for integration ' + pm.environment.get('integration_id'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/integrations/{{integration_id}}/sync",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "{{integration_id}}", "sync"]
            },
            "description": "Dispatches a background sync job. Set `integration_id` variable first."
          }
        },
        {
          "name": "Disconnect Integration",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Disconnected', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/integrations/{{integration_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "{{integration_id}}"]
            },
            "description": "⚠️ Permanently removes the integration and cascades to all PRs, issues, and reviews synced from it."
          }
        }
      ]
    },

    {
      "name": "📊 Dashboard",
      "description": "Overview stats and recent activity feed.",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has stats object', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.stats).to.be.an('object');",
                  "    pm.expect(json.stats).to.have.property('open_prs');",
                  "    pm.expect(json.stats).to.have.property('assigned_issues');",
                  "    pm.expect(json.stats).to.have.property('total_reviews');",
                  "    const s = json.stats;",
                  "    console.log('📊 Open PRs: ' + s.open_prs + ' | Issues: ' + s.assigned_issues + ' | Reviews: ' + s.total_reviews);",
                  "});",
                  "pm.test('Has charts object', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.charts).to.be.an('object');",
                  "    pm.expect(json.charts).to.have.property('prs_by_platform');",
                  "    pm.expect(json.charts).to.have.property('issues_by_status');",
                  "    pm.expect(json.charts).to.have.property('issues_by_priority');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/dashboard/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "dashboard", "stats"]
            },
            "description": "Returns: open PR count, assigned issue count, total review count, PRs by platform chart, issues by status chart, issues by priority chart."
          }
        },
        {
          "name": "Get Recent Activity",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has recent data', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.recent_prs).to.be.an('array');",
                  "    pm.expect(json.recent_issues).to.be.an('array');",
                  "    pm.expect(json.recent_reviews).to.be.an('array');",
                  "    console.log('🕐 Recent: ' + json.recent_prs.length + ' PRs | ' + json.recent_issues.length + ' Issues | ' + json.recent_reviews.length + ' Reviews');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/dashboard/recent",
              "host": ["{{base_url}}"],
              "path": ["api", "dashboard", "recent"]
            },
            "description": "Returns the last 10 PRs, 10 issues, and 10 reviews — sorted by most recently updated."
          }
        }
      ]
    },

    {
      "name": "🔀 Pull Requests",
      "description": "List, filter, and inspect pull requests across all platforms.",
      "item": [
        {
          "name": "List All PRs",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Paginated response', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.be.an('array');",
                  "    pm.expect(json).to.have.property('total');",
                  "    pm.expect(json).to.have.property('current_page');",
                  "    if (json.data.length > 0) {",
                  "        pm.collectionVariables.set('pr_id', json.data[0].id);",
                  "        pm.environment.set('pr_id', json.data[0].id);",
                  "        console.log('🔀 ' + json.total + ' total PRs | First ID: ' + json.data[0].id);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/pull-requests?page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "pull-requests"],
              "query": [
                { "key": "status", "value": "open", "description": "open | closed | merged | draft", "disabled": true },
                { "key": "platform", "value": "github", "description": "github | gitlab | bitbucket", "disabled": true },
                { "key": "repository", "value": "owner/repo", "description": "Exact repo name e.g. testuser/my-app", "disabled": true },
                { "key": "sort_by", "value": "updated_at", "description": "updated_at | created_at | title", "disabled": true },
                { "key": "sort_order", "value": "desc", "description": "asc | desc", "disabled": true },
                { "key": "page", "value": "1" }
              ]
            },
            "description": "All PRs for the authenticated user. Enable query params to filter. First PR ID is auto-saved to `pr_id`."
          }
        },
        {
          "name": "List Open PRs — GitHub only",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All are open and github', () => {",
                  "    pm.response.json().data.forEach(pr => {",
                  "        pm.expect(pr.state).to.equal('open');",
                  "        pm.expect(pr.integration.platform).to.equal('github');",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/pull-requests?status=open&platform=github",
              "host": ["{{base_url}}"],
              "path": ["api", "pull-requests"],
              "query": [
                { "key": "status", "value": "open" },
                { "key": "platform", "value": "github" }
              ]
            }
          }
        },
        {
          "name": "List Merged PRs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/pull-requests?status=merged",
              "host": ["{{base_url}}"],
              "path": ["api", "pull-requests"],
              "query": [{ "key": "status", "value": "merged" }]
            }
          }
        },
        {
          "name": "List PRs by Repository",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/pull-requests?repository=testuser/my-app",
              "host": ["{{base_url}}"],
              "path": ["api", "pull-requests"],
              "query": [{ "key": "repository", "value": "testuser/my-app", "description": "Change to your actual repo name" }]
            }
          }
        },
        {
          "name": "List Reviewed PRs",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has reviews on each PR', () => {",
                  "    pm.response.json().data.forEach(pr => {",
                  "        pm.expect(pr.reviews).to.be.an('array');",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/pull-requests/reviewed",
              "host": ["{{base_url}}"],
              "path": ["api", "pull-requests", "reviewed"]
            },
            "description": "PRs that the authenticated user has submitted a review on. Each PR includes its reviews array."
          }
        },
        {
          "name": "Get PR Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('PR has required fields', () => {",
                  "    const pr = pm.response.json().pull_request;",
                  "    pm.expect(pr).to.have.property('title');",
                  "    pm.expect(pr).to.have.property('state');",
                  "    pm.expect(pr).to.have.property('repository');",
                  "    pm.expect(pr).to.have.property('labels');",
                  "    pm.expect(pr.labels).to.be.an('array');",
                  "    pm.expect(pr).to.have.property('reviews');",
                  "    pm.expect(pr.reviews).to.be.an('array');",
                  "    pm.expect(pr).to.have.property('integration');",
                  "    console.log('🔀 PR: ' + pr.title + ' [' + pr.state + '] | ' + pr.reviews.length + ' review(s)');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/pull-requests/{{pr_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "pull-requests", "{{pr_id}}"]
            },
            "description": "Full PR detail with reviews and integration info. Uses `pr_id` variable (auto-set by List All PRs)."
          }
        }
      ]
    },

    {
      "name": "🐛 Issues",
      "description": "List, filter, and inspect issues across all platforms.",
      "item": [
        {
          "name": "List All Issues",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Paginated response', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.be.an('array');",
                  "    pm.expect(json).to.have.property('total');",
                  "    if (json.data.length > 0) {",
                  "        pm.collectionVariables.set('issue_id', json.data[0].id);",
                  "        pm.environment.set('issue_id', json.data[0].id);",
                  "        console.log('🐛 ' + json.total + ' total issues | First ID: ' + json.data[0].id);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/issues?page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "issues"],
              "query": [
                { "key": "type", "value": "bug", "description": "bug | task | feature", "disabled": true },
                { "key": "status", "value": "open", "description": "open | closed | in_progress", "disabled": true },
                { "key": "priority", "value": "critical", "description": "low | medium | high | critical", "disabled": true },
                { "key": "platform", "value": "github", "description": "github | gitlab | bitbucket", "disabled": true },
                { "key": "repository", "value": "owner/repo", "description": "Exact repo name", "disabled": true },
                { "key": "sort_by", "value": "updated_at", "description": "updated_at | created_at | priority", "disabled": true },
                { "key": "sort_order", "value": "desc", "description": "asc | desc", "disabled": true },
                { "key": "page", "value": "1" }
              ]
            },
            "description": "All issues for the authenticated user. Enable any query param to filter. First issue ID is auto-saved to `issue_id`."
          }
        },
        {
          "name": "List Open Critical Bugs",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All are critical open bugs', () => {",
                  "    pm.response.json().data.forEach(i => {",
                  "        pm.expect(i.type).to.equal('bug');",
