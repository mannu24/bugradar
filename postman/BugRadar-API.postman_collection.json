    {
      "name": "📁 Repositories",
      "description": "Per-repo tracking. List repos, toggle tracking on/off. Tracking a repo registers a GitHub webhook (best-effort) and triggers a sync.",
      "item": [
        {
          "name": "List Repositories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has repositories array', () => pm.expect(json.repositories).to.be.an('array'));",
                  "if (json.repositories && json.repositories.length) {",
                  "    console.log('Repos: ' + json.repositories.length + ' | tracked: ' + json.repositories.filter(r => r.tracked).length);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/integrations/{{integration_id}}/repositories",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "{{integration_id}}", "repositories"]
            },
            "description": "Lists all repos from the platform for this integration, each flagged tracked:true/false and webhook:true/false. Set integration_id first."
          }
        },
        {
          "name": "Track Repository",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Tracked', () => pm.expect(json.success).to.be.true);",
                  "console.log('Realtime (webhook) active: ' + json.realtime);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"repo_full_name\": \"{{repo_full_name}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/integrations/{{integration_id}}/repositories/track",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "{{integration_id}}", "repositories", "track"]
            },
            "description": "Toggle a repo ON. Set repo_full_name variable (e.g. manu/my-app). Registers a GitHub webhook (needs admin:repo_hook scope + repo admin rights) and triggers a sync. If webhook registration fails, polling still covers the repo (realtime:false)."
          }
        },
        {
          "name": "Untrack Repository",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Untracked', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"repo_full_name\": \"{{repo_full_name}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/integrations/{{integration_id}}/repositories/track",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "{{integration_id}}", "repositories", "track"]
            },
            "description": "Toggle a repo OFF. Removes the webhook and stops syncing. Already-synced data is KEPT (Option A)."
          }
        }
      ]
    },
